{
    "family": "desaconnect-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "pelayanan-backend-container",
            "image": "PLACEHOLDER_IMAGE",
            "portMappings": [
                {
                    "containerPort": 5000,
                    "hostPort": 5000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                { "name": "PORT", "value": "5000" },
                { "name": "NODE_ENV", "value": "production" }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-create-group": "true",
                    "awslogs-group": "/ecs/desaconnect-task",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::446598504794:role/ecsTaskExecutionRole"
}